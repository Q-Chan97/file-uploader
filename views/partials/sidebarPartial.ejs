<section class="sidebar-container">
    <a href="/" class="sidebar-logo-container">
        <div class="sidebar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" height="100%" viewBox="0 -960 960 960" width="100%" fill="#fff"><path d="M160-160q-33 0-56.5-23.5T80-240v-480q0-33 23.5-56.5T160-800h240l80 80h320q33 0 56.5 23.5T880-640v400q0 33-23.5 56.5T800-160H160Zm328-240-65 65 56 56 161-161-161-161-56 56 65 65H320v80h168Z"/></svg>
        </div>
        <h1>Vaultly</h1>
    </a>
    <h2>Welcome, <%= locals.user.username %></h2>
    <button class="create-folder-button">Create Folder</button>
    <div class="folders-container">
        <% if (locals.folders) { %>
            <% locals.folders.forEach((folder) => { %>
            <a href="/folder/<%= folder.id %>" class="folder-link">
                <%= folder.name %>
            </a>
        <% }) %>
        <% } %>
    </div>
    <a href="/log-out" class="log-out-button">Log Out</a>
</section>